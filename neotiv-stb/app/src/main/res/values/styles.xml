<resources>
    <!-- Use a basic Android theme that works on ALL Android versions (API 21+) -->
    <!-- NoActionBar variant avoids the deprecated NoTitleBar.Fullscreen that crashes on Android 12+ -->
    <style name="Theme.NeotivTV" parent="@android:style/Theme.Material.NoActionBar.Fullscreen">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
