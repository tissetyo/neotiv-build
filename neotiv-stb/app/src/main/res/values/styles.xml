<resources>
    <!--
        Use Theme.DeviceDefault — this guarantees the device's own native theme is used.
        Works on all Android versions API 14+ and adapts to whatever the manufacturer provides.
        BigdroidOS, stock Android TV, AOSP — all have their own DeviceDefault.
    -->
    <style name="Theme.NeotivTV" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
